rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read: student ID → email lookup (needed for sign-in before auth)
    match /studentLookup/{studentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles: only the owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress: student can read/write their own; parents can read any
    match /progress/{studentId} {
      allow read, write: if request.auth != null;
    }

    // Parental controls: authenticated users only
    match /controls/{studentId} {
      allow read, write: if request.auth != null;
    }
  }
}
