{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "eritrean-info",
      "public": "eritrean-info",
      "cleanUrls": true,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**/.well-known/**",
          "headers": [
            { "key": "Content-Type", "value": "application/json" },
            { "key": "Access-Control-Allow-Origin", "value": "*" }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "riglog",
      "public": "riglog",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.@(js|css|png|jpg|svg|ico|webmanifest)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        }
      ]
    },
    {
      "target": "admin",
      "public": "admin",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    },
    {
      "target": "tigrinya-school",
      "public": "tigrinya-school",
      "cleanUrls": true,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    }
  ]
}
